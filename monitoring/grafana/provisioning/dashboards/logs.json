      "targets": [{ "expr": "{job=\"flask-app\"} |= \"chaos\" ", "refId": "A" }],
      "title": "Chaos Monkey Logs", "type": "logs"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 30 }, "id": 31,
